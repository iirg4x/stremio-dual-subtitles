# Dual Subtitles Addon Configuration
# Copy this file to .env and configure your settings

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Port for the addon server (default: 7000)
PORT=7000

# Host to bind to (default: 0.0.0.0 for all interfaces)
HOST=0.0.0.0

# External URL for accessing the addon remotely
# Required if running behind a reverse proxy or accessing from another device
# Examples:
# - Local network: http://192.168.1.100:7000
# - Public domain: https://dualsubtitles.example.com
# - Ngrok tunnel: https://abc123.ngrok.io
# EXTERNAL_URL=http://localhost:7000

# Custom addon name (useful for distinguishing instances)
# ADDON_NAME=My Dual Subtitles

# Optional extra subtitle sources through Wyzie Subs.
# Get a free key from https://sub.wyzie.io/redeem, then set this to enable
# additional IMDb-based sources such as Podnapisi and YIFY.
# WYZIE_API_KEY=wyzie-your-key
# WYZIE_SOURCES=podnapisi,yify
# WYZIE_BASE_URL=https://sub.wyzie.io

# SubDL subtitle database (large multilingual database, good for anime + mainstream).
# Get a free API key at https://subdl.com/app/key
# SUBDL_API_KEY=your-subdl-key

# Jimaku anime subtitle database (jimaku.cc).
# Enabled by default for anime content. An API key increases rate limits.
# JIMAKU_API_KEY=your-jimaku-key

# ============================================================================
# LOCAL SUBTITLE TRANSLATOR
# ============================================================================
# Set LIBRETRANSLATE_URL to enable automatic subtitle translation when no
# secondary-language subtitle is available from any source.
# You can self-host LibreTranslate (https://libretranslate.com/) or use a
# public instance (note: public instances may have rate limits).
# Examples:
#   Self-hosted: LIBRETRANSLATE_URL=http://localhost:5000
#   Public:      LIBRETRANSLATE_URL=https://libretranslate.de
# LIBRETRANSLATE_URL=http://localhost:5000
# LIBRETRANSLATE_API_KEY=your-key  (only needed on protected instances)

# Rate limiting (per IP)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=60

# ============================================================================
# OPTIONAL: DEBUG MODE
# ============================================================================

# Enable debug logging (set to 'true' for verbose output)
# NEXT_PUBLIC_DEBUG_MODE=true
# DEBUG_MODE=true

# ============================================================================
# ANALYTICS PROTECTION
# ============================================================================

# Secret key to protect /stats page (only you can access analytics)
# Access via: https://your-domain.com/stats?key=YOUR_SECRET_KEY
# If not set, analytics page is public (not recommended)
ANALYTICS_SECRET=your-secret-key-here
